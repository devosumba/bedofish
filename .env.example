# ─────────────────────────────────────────────────────────
# Bedo Fish — Environment Variables Reference
# Copy to .env and fill in real values
# The .env file must NEVER be committed to git
# ─────────────────────────────────────────────────────────

# SERVER
NODE_ENV=development
PORT=4000
API_BASE_URL=https://api.bedofish.com

# DATABASE (Neon in production, Docker locally)
DATABASE_URL=postgresql://user:password@host:5432/bedofish?sslmode=require
DATABASE_URL_LOCAL=postgresql://bedofish_user:bedofish_local_password@localhost:5432/bedofish

# REDIS (Upstash in production, Docker locally)
# Format: rediss://default:<token>@<host>.upstash.io:6379
REDIS_URL=replace_with_upstash_redis_url
REDIS_URL_LOCAL=redis://localhost:6379

# GOOGLE OAUTH (via NextAuth.js / Auth.js v5)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
#                           https://bedofish.com/api/auth/callback/google
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret

# NEXTAUTH (Auth.js v5)
# Generate with: openssl rand -hex 32
AUTH_SECRET=replace_with_256bit_random_hex_string
NEXTAUTH_URL=http://localhost:3000

# API JWT (for API-to-API calls, not user auth)
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_256bit_random_hex_string
JWT_ACCESS_EXPIRES_IN=15m

# PAYHERO M-PESA (SENSITIVE — backend only, never expose to browser)
PAYHERO_USERNAME=replace_with_payhero_username
PAYHERO_PASSWORD=replace_with_payhero_password
PAYHERO_CHANNEL_ID=replace_with_numeric_channel_id
PAYHERO_WEBHOOK_SECRET=replace_with_webhook_hmac_secret

# AFRICA'S TALKING SMS (SENSITIVE — backend only)
AT_API_KEY=replace_with_africas_talking_api_key
AT_USERNAME=replace_with_at_username
AT_SENDER_ID=BEDOFISH

# RESEND EMAIL (SENSITIVE — backend only)
RESEND_API_KEY=re_replace_with_resend_api_key
RESEND_FROM=orders@bedofish.com

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_api_key
CLOUDINARY_API_SECRET=replace_with_api_secret

# NEXT.JS FRONTEND PUBLIC VARIABLES
# WARNING: NEXT_PUBLIC_ is exposed to the browser.
# NEVER put PayHero, JWT, DB, or any secret here.
NEXT_PUBLIC_API_URL=https://api.bedofish.com/v1
NEXT_PUBLIC_SITE_URL=https://bedofish.com
